# =============================================================================
# Whop SaaS Starter - Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# See README.md for setup instructions.

# -----------------------------------------------------------------------------
# Database (Required)
# -----------------------------------------------------------------------------
# PostgreSQL connection string. Works with Vercel Postgres, Supabase, Neon, etc.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# -----------------------------------------------------------------------------
# Whop OAuth (Required)
# -----------------------------------------------------------------------------
# Create an app at https://whop.com/dashboard/developer
# Your App ID (public, used as OAuth client_id)
NEXT_PUBLIC_WHOP_APP_ID="app_xxxxxxxxx"

# Your App API Key (secret, used for server-side API calls)
WHOP_API_KEY="apik_xxxxxxxxx"

# Your OAuth Client Secret (from your app's OAuth settings in the Developer Dashboard)
# This is different from the API key — it's used for the OAuth token exchange.
WHOP_CLIENT_SECRET="your_client_secret_here"

# -----------------------------------------------------------------------------
# Whop Webhooks (Required for payments)
# -----------------------------------------------------------------------------
# Webhook secret from your Whop app's webhook settings
WHOP_WEBHOOK_SECRET="your_webhook_secret_here"

# -----------------------------------------------------------------------------
# Session (Required)
# -----------------------------------------------------------------------------
# A random 32+ character string used to sign session JWTs.
# Generate one with: openssl rand -base64 32
SESSION_SECRET="your-random-secret-here-change-me"

# -----------------------------------------------------------------------------
# Whop Plans (Required for paid tiers)
# -----------------------------------------------------------------------------
# Create plans in your Whop dashboard and paste the plan IDs here.
# These are used on the pricing page and to identify plan tiers in webhooks.
# Create a $0 plan in Whop for free users so all customers are managed in Whop.
NEXT_PUBLIC_WHOP_FREE_PLAN_ID="plan_xxxxxxxxx"
NEXT_PUBLIC_WHOP_PRO_PLAN_ID="plan_xxxxxxxxx"
NEXT_PUBLIC_WHOP_ENTERPRISE_PLAN_ID="plan_xxxxxxxxx"

# -----------------------------------------------------------------------------
# App Configuration
# -----------------------------------------------------------------------------
# Your app's public URL (used for OAuth redirect and webhook URLs)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
